gem 'database_cleaner'
gem 'elasticsearch-extensions'
gem 'method_source'
gem 'rake'
gem 'redis', require: false
gem 'rspec', '>= 3.7.0'
gem 'rspec-github', require: false
gem 'rspec-collection_matchers'
gem 'rubocop', '1.84.2'
gem 'sqlite3', '~> 2.1'
gem 'timecop'
gem 'unparser', '~> 0.6.15'

# Pin elasticsearch gem to the correct major for CI based on ES_MAJOR
case ENV.fetch('ES_MAJOR', '8')
when '8'
  gem 'elasticsearch', '>= 8', '< 9'
when '9'
  gem 'elasticsearch', '>= 9', '< 10'
end
